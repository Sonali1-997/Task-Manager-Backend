# Application
PORT=3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=tms

# Set to true ONLY in local dev if you want TypeORM to auto-sync the schema.
# Leave false — the schema is owned by database/schema.sql.
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Auth / JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=1d
