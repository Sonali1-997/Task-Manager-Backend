# Application
PORT=3000

# Database (Microsoft SQL Server)
DB_HOST=localhost
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=Your_strong_password1
DB_DATABASE=tms

# TLS. The mssql driver encrypts by default. For local SQL Server / Docker
# with a self-signed cert, keep both true. In production with a trusted cert,
# set DB_TRUST_SERVER_CERT=false.
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true

# Set to true ONLY in local dev if you want TypeORM to auto-sync the schema.
# Leave false — the schema is owned by database/schema.sql.
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Auth / JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=1d
